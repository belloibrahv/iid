# Production Environment Variables
# Copy this file to .env and fill in the actual values

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0

# Security (IMPORTANT: Generate strong random keys for production)
SECRET_KEY=your-secret-key-here-generate-with-python-secrets
API_KEY=your-api-key-here-generate-with-python-secrets

# Database Configuration
# For Render, DATABASE_URL is automatically provided by Render PostgreSQL
# For local development with PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/ids_db
# For SQLite (development only):
# DATABASE_PATH=/path/to/development/ids.db

# Session Configuration (optional overrides)
SESSION_PERMANENT=False
SESSION_TYPE=filesystem

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Logging
LOG_LEVEL=INFO
