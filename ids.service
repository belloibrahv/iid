[Unit]
Description=IDS Flask Application
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/ids
Environment="PATH=/var/www/ids/venv/bin"
ExecStart=/var/www/ids/venv/bin/gunicorn --workers 3 --bind unix:ids.sock -m 007 wsgi:app
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
